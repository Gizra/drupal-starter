<div class="bg-transparent">
  <div class="container-narrow w-full">
    <div class="relative rounded-lg border border-gray-300 w-full h-full overflow-hidden bg-gray-100 p-6 md:px-8">
      <div class="flex flex-col gap-y-8 md:gap-y-10 items-center">

        <div class="text-xl md:text-2xl lg:text-3xl font-bold text-center">{{ title }}</div>

        {% if body %}
          <div class="prose max-w-3xl">{{ body }}</div>
        {% endif %}

        {% include '@server_theme/server-theme-button.html.twig' with {
          button_type: 'primary',
          url: link_url,
          title: link_text,
          open_new_tab: open_new_tab ?? false,
        } only %}

      </div>
    </div>
  </div>
</div>
