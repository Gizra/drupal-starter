#!/bin/bash

## Description: Run PHPunit tests inside the web container.
## Usage: phpunit [arguments]
## Example: "ddev phpunit" or "ddev phpunit web/modules/custom/server_general".

# Available options:
#
#   Run all tests:
#     ddev phpunit
#
#   Run tests in a specific module:
#     ddev phpunit web/modules/custom/server_general
#
#   Filter by class name:
#     ddev phpunit --filter ServerGeneralHomepageTest
#
#   Filter by method name:
#     ddev phpunit --filter testHomeFeaturedContent
#
#   Run a specific testsuite (unit, kernel, existing-site, existing-site-javascript):
#     ddev phpunit --testsuite existing-site
#
#   Run tests in a specific group:
#     ddev phpunit --group rollbar
#
#   Exclude a group:
#     ddev phpunit --exclude-group rollbar
#
#   Run a single test file:
#     ddev phpunit web/modules/custom/server_general/tests/src/ExistingSite/ServerGeneralHomepageTest.php
#
# Note: @group rollbar tests are excluded by default (see phpunit.xml.dist).

set -euo pipefail

mkdir -p /var/www/html/test-results /var/www/html/test-html-output
PHP_MEMORY_LIMIT=2G ./vendor/bin/phpunit -c phpunit.xml.dist --log-junit /var/www/html/test-results/junit.xml "$@"
